{
  "id": "hedgedoc",
  "name": "HedgeDoc",
  "version": "0.1.0",
  "description": "Embed a self-hosted HedgeDoc instance inside Uncorded.",
  "author": "Uncorded",
  "icon": "/icon.png",
  "scope": "server",
  "permissions": [
    "server.read",
    "channels.read",
    "storage.read",
    "storage.write"
  ],
  "runtime": {
    "image": "hedgedoc-plugin:0.1.0",
    "port": 3017,
    "healthCheck": "/health"
  },
  "ui": {
    "type": "page"
  }
}
